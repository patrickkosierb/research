{"nbformat":4,"nbformat_minor":0,"metadata":{"colab":{"provenance":[],"authorship_tag":"ABX9TyMNi3OKVO6cAADdSbnqTlut"},"kernelspec":{"name":"python3","display_name":"Python 3"},"language_info":{"name":"python"}},"cells":[{"cell_type":"code","execution_count":1,"metadata":{"id":"AL1ZmOrEBlJS","executionInfo":{"status":"ok","timestamp":1692199795646,"user_tz":240,"elapsed":7689,"user":{"displayName":"Yuandi Wu","userId":"10072901507359294189"}}},"outputs":[],"source":["import torch\n","import torch.nn as nn\n","\n","class SimpleLSTM(nn.Module):\n","    def __init__(self, input_size, hidden_size, num_layers, output_size):\n","        super(SimpleLSTM, self).__init__()\n","        self.lstm = nn.LSTM(input_size, hidden_size, num_layers, batch_first=True)\n","        self.fc = nn.Linear(hidden_size, output_size)\n","\n","    def forward(self, x):\n","        out, _ = self.lstm(x)\n","        out = self.fc(out[:, -1, :])\n","        return out\n"]},{"cell_type":"code","source":["# Dummy data and setup\n","model = SimpleLSTM(10, 50, 2, 1)\n","criterion = nn.MSELoss()\n","optimizer = torch.optim.Adam(model.parameters(), lr=0.001)\n","data = torch.randn(100, 10, 10)\n","labels = torch.randn(100, 1)\n","\n","# Training loop\n","num_epochs = 5\n","for epoch in range(num_epochs):\n","    outputs = model(data)\n","    loss = criterion(outputs, labels)\n","\n","    optimizer.zero_grad()\n","    loss.backward()\n","    optimizer.step()\n","\n","    # Save model checkpoint\n","    checkpoint = {\n","        'epoch': epoch + 1,\n","        'state_dict': model.state_dict(),\n","        'optimizer': optimizer.state_dict(),\n","        'loss': loss.item()\n","    }\n","    torch.save(checkpoint, f'checkpoint_epoch_{epoch + 1}.pth')\n","\n","    print(f\"Epoch [{epoch + 1}/{num_epochs}], Loss: {loss.item():.4f}\")\n"],"metadata":{"colab":{"base_uri":"https://localhost:8080/"},"id":"OapgxxhNBspN","executionInfo":{"status":"ok","timestamp":1692199796314,"user_tz":240,"elapsed":673,"user":